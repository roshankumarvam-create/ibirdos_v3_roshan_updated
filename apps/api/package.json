    "@ibirdos/types": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/core": "^10.4.7",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.7",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
