// PRODUCTION COMPLETION — AI Insights Engine
// =====================================================================

enum InsightKind {
  PRICE_SPIKE         // ingredient price jumped > X%
  MARGIN_RISK         // recipe margin dropped below target
  WASTE_PATTERN       // recurring waste by reason
  VENDOR_OPPORTUNITY  // cheaper vendor for an ingredient
  REORDER_SUGGEST     // stock will run out before next planned receive
  MENU_OPTIMIZATION   // demand vs margin recommendation
  FORECAST_DEMAND     // upcoming-event demand projection
  ANOMALY             // statistical outlier (yield drop, unusual usage)

  @@map("insight_kind")
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL

  @@map("insight_severity")
}

enum InsightStatus {
  ACTIVE
  ACKNOWLEDGED
  DISMISSED
  RESOLVED

  @@map("insight_status")
}

model Insight {
  id              String           @id @default(cuid())
  workspaceId     String           @map("workspace_id")
  kind            InsightKind
  severity        InsightSeverity  @default(INFO)
  status          InsightStatus    @default(ACTIVE)
  title           String
  body            String           @db.Text
  /// Optional structured payload — { ingredientId, recipeId, oldPrice, newPrice, delta }
  payloadJson     Json?            @map("payload_json")
  /// LLM-generated suggested actions
  suggestedActions Json?           @map("suggested_actions")
  /// Numerical relevance score 0..1 for sorting on the dashboard
  relevanceScore  Decimal          @default(0.5) @db.Decimal(3, 2) @map("relevance_score")
  /// Generation provenance — for explainability + audit
  generatedBy     String           @map("generated_by")  // "ai" | "rule:price_spike" | "ai:gpt-4o"
  aiModel         String?          @map("ai_model")
  aiTokens        Int?             @map("ai_tokens")
  acknowledgedById String?         @map("acknowledged_by_id")
  acknowledgedAt  DateTime?        @map("acknowledged_at")
  expiresAt       DateTime?        @map("expires_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([workspaceId, status, severity, createdAt(sort: Desc)])
  @@index([workspaceId, kind])
  @@map("insights")
}

