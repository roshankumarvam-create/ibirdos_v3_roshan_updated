// =====================================================================
// AI Insights — production intelligence layer
// =====================================================================

enum InsightKind {
  PRICE_SPIKE             // ingredient went up significantly
  MARGIN_EROSION          // recipe margin dropped below target
  WASTE_PATTERN           // recurring waste at scale
  REORDER_RECOMMENDATION  // forecasted stockout
  VENDOR_OPPORTUNITY      // cheaper alternative vendor detected
  MENU_OPTIMIZATION       // suggest portion / pricing change
  DEMAND_FORECAST         // upcoming demand spike (events)
  GENERAL

  @@map("insight_kind")
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL

  @@map("insight_severity")
}

enum InsightStatus {
  OPEN
  ACKNOWLEDGED
  ACTIONED
  DISMISSED
  EXPIRED

  @@map("insight_status")
}

model Insight {
  id              String          @id @default(cuid())
  workspaceId     String          @map("workspace_id")
  kind            InsightKind
  severity        InsightSeverity @default(INFO)
  status          InsightStatus   @default(OPEN)

  title           String          // one-line summary
  body            String          // longer markdown body with explanation
  /// AI-generated suggested action (markdown)
  recommendation  String?
  /// Confidence (0-1) — how strongly the model believes this is actionable
  confidence      Decimal         @default(0.5) @db.Decimal(3, 2)

  /// Structured payload backing the insight — entity refs, deltas
  metadataJson    Json            @map("metadata_json")

  /// What entities this insight refers to (for click-through)
  entityRefs      Json?           @map("entity_refs")  // {ingredientId?, recipeId?, vendorId?, eventId?}

  /// AI generation metadata
  aiModel         String?         @map("ai_model")
  aiTokensInput   Int?            @map("ai_tokens_input")
  aiTokensOutput  Int?            @map("ai_tokens_output")
  aiCostCents     Int?            @map("ai_cost_cents")

  acknowledgedAt  DateTime?       @map("acknowledged_at")
  acknowledgedById String?        @map("acknowledged_by_id")
  dismissedAt     DateTime?       @map("dismissed_at")
  expiresAt       DateTime?       @map("expires_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt      @map("updated_at")

  @@index([workspaceId, status, severity])
  @@index([workspaceId, kind, createdAt(sort: Desc)])
  @@map("insights")
}

// =====================================================================
// Notifications — in-app delivery for cross-feature events
// =====================================================================

enum NotificationKind {
  LOW_STOCK
  INSIGHT
  INVOICE_EXTRACTION_FAILED
  KITCHEN_TASK_BLOCKED
  EVENT_REMINDER
  BILLING_PAYMENT_FAILED
  GENERIC

  @@map("notification_kind")
}

model Notification {
  id            String           @id @default(cuid())
  workspaceId   String           @map("workspace_id")
  /// Null = workspace-wide (everyone in the workspace sees it). Set = user-specific.
  userId        String?          @map("user_id")
  kind          NotificationKind
  title         String
  body          String?
  /// Click-through destination — frontend route
  linkPath      String?          @map("link_path")
  /// Reference IDs for context
  entityRefs    Json?            @map("entity_refs")
  /// Lifecycle
  readAt        DateTime?        @map("read_at")
  dismissedAt   DateTime?        @map("dismissed_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([workspaceId, userId, readAt])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("notifications")
}
