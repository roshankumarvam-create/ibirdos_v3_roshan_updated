enum BillingPlanTier {
  TRIAL
  STARTER
  GROWTH
  SCALE
  ENTERPRISE

  @@map("billing_plan_tier")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  INCOMPLETE
  PAUSED

  @@map("subscription_status")
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE

  @@map("billing_invoice_status")
}

model BillingPlan {
  id              String          @id @default(cuid())
  tier            BillingPlanTier @unique
  name            String
  /// Monthly base price in cents
  monthlyPriceCents Int           @map("monthly_price_cents")
  /// Included seats; overage charged per seat
  includedSeats   Int             @default(3) @map("included_seats")
  perSeatPriceCents Int           @default(0) @map("per_seat_price_cents")
  /// Stripe price ID
  stripePriceId   String?         @unique @map("stripe_price_id")
  /// Feature flags as JSON: { ai: true, vendorApi: true, ... }
  featuresJson    Json            @default("{}") @map("features_json")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at")

  subscriptions   Subscription[]

  @@map("billing_plans")
}

model Subscription {
  id                  String              @id @default(cuid())
  workspaceId         String              @unique @map("workspace_id")
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planId              String              @map("plan_id")
  status              SubscriptionStatus  @default(TRIALING)
  /// Stripe IDs
  stripeCustomerId    String?             @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  /// Current billing period
  currentPeriodStart  DateTime?           @map("current_period_start")
  currentPeriodEnd    DateTime?           @map("current_period_end")
  trialEndsAt         DateTime?           @map("trial_ends_at")
  cancelledAt         DateTime?           @map("cancelled_at")
  cancelAtPeriodEnd   Boolean             @default(false) @map("cancel_at_period_end")
  /// Cached seat count for metered billing
  currentSeats        Int                 @default(1) @map("current_seats")
  pastDueSince        DateTime?           @map("past_due_since")
  metadata            Json?               @default("{}")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt      @map("updated_at")

  plan                BillingPlan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices            BillingInvoice[]

  @@index([status])
  @@map("subscriptions")
}

model BillingInvoice {
  id                  String              @id @default(cuid())
  workspaceId         String              @map("workspace_id")
  subscriptionId      String              @map("subscription_id")
  stripeInvoiceId     String              @unique @map("stripe_invoice_id")
  status              BillingInvoiceStatus
  amountDueCents      Int                 @map("amount_due_cents")
  amountPaidCents     Int                 @default(0) @map("amount_paid_cents")
  currency            String              @default("USD")
  hostedInvoiceUrl    String?             @map("hosted_invoice_url")
  invoicePdfUrl       String?             @map("invoice_pdf_url")
  periodStart         DateTime?           @map("period_start")
  periodEnd           DateTime?           @map("period_end")
  paidAt              DateTime?           @map("paid_at")
  attemptCount        Int                 @default(0) @map("attempt_count")
  failureMessage      String?             @map("failure_message")
  createdAt           DateTime            @default(now()) @map("created_at")

  subscription        Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("billing_invoices")
}

model StripeWebhookEvent {
  id          String   @id          // stripe event id (idempotency key)
  type        String
  payloadJson Json     @map("payload_json")
  processedAt DateTime? @map("processed_at")
  error       String?
  receivedAt  DateTime @default(now()) @map("received_at")

  @@index([type, receivedAt(sort: Desc)])
  @@map("stripe_webhook_events")
}

