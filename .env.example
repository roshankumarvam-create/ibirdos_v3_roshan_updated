# =====================================================================
# IBirdOS V3 — environment template
# Copy to .env and fill in. Validated by packages/config at boot.
# =====================================================================

# ---- Core ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Database (matches docker-compose.yml defaults) ----
DATABASE_URL=postgresql://ibirdos:ibirdos_dev_password@localhost:5432/ibirdos

# ---- Redis (sessions, queues, cache) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_me_with_at_least_32_random_characters_abcdef
AUTH_SESSION_TTL_HOURS=168
AUTH_COOKIE_NAME=ibirdos.sid
# AUTH_COOKIE_DOMAIN=.ibirdos.com  # set in production

# ---- Argon2id password hashing (defaults are OWASP-recommended) ----
ARGON2_MEMORY_KIB=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ---- Stripe ----
# STRIPE_REQUIRED=true in production. =false bypasses Stripe entirely
# (self-hosted / dev / on-prem deployment).
STRIPE_REQUIRED=false
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID=price_xxx

# ---- OpenAI ----
# Optional in dev (fixtures used); required in production.
# OPENAI_API_KEY=sk-xxx
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o-mini

# ---- Storage (Cloudflare R2 in prod; MinIO locally) ----
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=ibirdos
R2_SECRET_ACCESS_KEY=ibirdos_dev_password
R2_BUCKET=ibirdos-uploads
# R2_PUBLIC_URL=https://uploads.ibirdos.com

# ---- App URLs ----
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# ---- OpenAI (additional models) ----
OPENAI_INSIGHTS_MODEL=gpt-4o-mini
AI_INSIGHTS_MODEL=gpt-4o-mini

# ---- Stripe (production billing) ----
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_PORTAL_RETURN_URL=https://workspace.ibirdos.com/billing

# ---- Vendor integrations (production) ----
# SYSCO_API_BASE=https://api.sysco.com
# SYSCO_CLIENT_ID=xxx
# SYSCO_CLIENT_SECRET=xxx
# USFOODS_API_BASE=https://api.usfoods.com
# USFOODS_CLIENT_ID=xxx
# USFOODS_CLIENT_SECRET=xxx

# ---- Observability ----
# SENTRY_DSN=https://xxx@sentry.io/xxx
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true
APP_VERSION=dev

# ---- Insights scheduling ----
INSIGHTS_GENERATION_CRON=0 6 * * *
