{
  "name": "ibirdos",
  "version": "0.1.0",
  "private": true,
  "description": "IBirdOS — AI operating system for commercial kitchens",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "db:generate": "pnpm --filter @ibirdos/db prisma:generate",
    "db:migrate": "pnpm --filter @ibirdos/db prisma:migrate",
    "db:deploy": "pnpm --filter @ibirdos/db prisma:deploy",
    "db:studio": "pnpm --filter @ibirdos/db prisma:studio",
    "db:reset": "pnpm --filter @ibirdos/db prisma:reset",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "setup": "bash scripts/setup.sh",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5",
    "@playwright/test": "^1.49.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
